# El procesador_simple.py probará los proveedores en este orden:
#   1. Groq (si GROQ_API_KEY está definida)
#   2. Google AI Studio (si GOOGLE_API_KEY está definida)
#   3. Ollama local (por defecto, sin clave)

# --- Groq (capa gratuita disponible en https://console.groq.com) ---
# GROQ_API_KEY=gsk_...

# --- Google AI Studio (capa gratuita en https://aistudio.google.com) ---
# GOOGLE_API_KEY=AIza...

# --- Ollama local / Google Colab (ver ollama_colab.ipynb) ---
OLLAMA_MODEL=qwen:7b
OLLAMA_AGENT_MODEL=qwen2.5-coder:7b
OLLAMA_BASE_URL=http://localhost:11434
